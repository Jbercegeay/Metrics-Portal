# Existing Smartsheet settings remain required during the compatibility period.
DEPT_PL_API_TOKEN=
DEPT_PL_CONFIG_SHEET_ID=
DEPT_PL_MASTER_LOG_SHEET_ID=
DEPT_PL_DEFECT_SEEDS_SHEET_ID=
DEPT_PTFE_API_TOKEN=
DEPT_PTFE_CONFIG_SHEET_ID=
DEPT_PTFE_MASTER_LOG_SHEET_ID=
DEPT_PTFE_STANDARDS_SHEET_ID=
DEPT_PTFE_ITEMS_SHEET_ID=
DEPT_PTFE_JOB_LOG_SHEET_ID=
ALLOW_PTFE_MASTER_LOG_WRITES=false
DEPT_PI_API_TOKEN=
DEPT_PI_CONFIG_SHEET_ID=
DEPT_PI_MASTER_LOG_SHEET_ID=
DEPT_PI_STANDARDS_SHEET_ID=
DEPT_PI_ITEMS_SHEET_ID=
DEPT_PI_JOB_LOG_SHEET_ID=
ALLOW_PI_MASTER_LOG_WRITES=false

# PostgreSQL foundation. Keep both flags false until the database is installed,
# migrated, backed up, and verified in the target environment.
DATABASE_ENABLED=false
DATABASE_REQUIRED=false
DATABASE_URL=postgresql://metrics_portal_app:replace-me@127.0.0.1:5432/metrics_portal
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
SERVER_HOST=0.0.0.0
CORS_ORIGIN=http://localhost:3000
